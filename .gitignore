# Python
__pycache__/
*.pyc
*.pyo

# Virtual Environment
.venv/
venv/

# macOS
.DS_Store

# PyCharm / IDE
.idea/
.vscode/

# Cursor local state (keep skills in repo)
.cursor/*
!.cursor/skills/
!.cursor/skills/**
!.cursor/rules/
!.cursor/rules/**
